# import necessary libraries
import pandas as pd
import numpy as np
from sklearn.model_selection import train_test_split
from sklearn.linear_model import LinearRegression
from sklearn.metrics import mean_squared_error
from sklearn.preprocessing import MinMaxScaler

# loading the CSV data
data = pd.read_csv('./workspace/data/insurance.csv')

# drop rows with missing values
data = data.dropna()

# Feature Engineering
# One-hot encoding for categorical variables
data = pd.get_dummies(data)

# Scale numerical variables (except the target column)
scaler = MinMaxScaler()
for col in data.columns:
    if data[col].dtype in ['int64', 'float64'] and col != 'charges':
        data[col] = scaler.fit_transform(data[[col]])

# split the data into train and test sets
X = data.drop('charges', axis=1)
y = data['charges']
X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.2)

# model training - Linear Regression
model = LinearRegression()
model.fit(X_train, y_train)

# Predict
y_pred = model.predict(X_test)

# Report RMSE on both training and test set
print('Root Mean Squared Error:')
print('Test set: ', mean_squared_error(y_test, y_pred, squared=False))
