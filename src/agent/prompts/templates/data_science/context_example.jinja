from typing import *
import pandas as pd
from hebo.design_space.design_space import DesignSpace
from hebo.optimizers.hebo import HEBO
import os
import numpy as np
import re

# this must be always added
from pymoo.config import Config
Config.warnings['not_compiled'] = False

# this must be always added: logic synthesis executable, reference sequence, available operators,
ABC_EXE = "./third_party/abc"
REF_SEQ = "balance; rewrite; refactor; &get; &fraig; &put"
OPERATORS = ["rewrite", "rewrite -z", "refactor", "refactor -z", "resub", "resub -z", "balance", "&get; &fraig; &put", "&get; &sopb; &put", "&get; &blut; &put", "&get; &dsdb; &put"]
SEQ_LEN = 20

circuit_path = "./data/max.blif"

def eval_seq(seq: str) -> Dict[str, float]:
    """
    Args:
        seq: a string representing a sequence of logic synthesis operators

    Returns:
        res: a dictionary with keys "size" and "level"
    """
    out = os.popen(f'{ABC_EXE} -c "read {circuit_path}; strash; {seq}; if -K 6; print_stats;"').read()
    res = {}
    for line in out.split("\n"):
        if "lev =" not in line:
            continue
        res["level"] = int(re.findall("lev *= *[0-9]+", line)[0].split("=")[-1])
        res["size"] = int(re.findall("nd *= *[0-9]+", line)[0].split("=")[-1])
    if len(res) == 0:
        print(out)
    return res

ref_stats = eval_seq(REF_SEQ)

def compute_qor(seq_op_inds: np.ndarray) -> np.ndarray:
    seq = ";".join([OPERATORS[seq_op_ind] for seq_op_ind in seq_op_inds])
    stats = eval_seq(seq)
    qor = stats["size"] / ref_stats["size"] + stats["level"] / ref_stats["level"]
    return np.array([[qor]])


logic_synth_search_space = DesignSpace().parse([
    {'name' : f'op{i}', 'type' : 'cat', 'categories': list(range(len(OPERATORS)))} for i in range(SEQ_LEN)
])
logic_synth_optimizer = HEBO(logic_synth_search_space)

for i in range(10):
    seq_op_inds = logic_synth_optimizer.suggest(n_suggestions=1)
    qor = compute_qor(seq_op_inds.values.flatten())
    logic_synth_optimizer.observe(seq_op_inds, qor)

# get the best sequence and associated QoR
best_seq = [OPERATORS[i] for i in logic_synth_optimizer.best_x.values[0]]
print(f'Best logic synthesis sequence: {best_seq}')
print(f'Best QoR: {logic_synth_optimizer.best_y}')
```
