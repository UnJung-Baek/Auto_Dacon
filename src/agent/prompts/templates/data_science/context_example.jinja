from sklearn.neural_network import MLPRegressor
import pandas as pd
from sklearn.model_selection import train_test_split
import numpy as np
from hebo.design_space.design_space import DesignSpace
from hebo.optimizers.hebo import HEBO
# this must be always added
from pymoo.config import Config
Config.warnings['not_compiled'] = False

# load the dataset
df = pd.read_csv("data/insurance.csv", sep=',')

# transform the code to one-hot
data_encoded = pd.get_dummies(df)

# create the X and y
X_data = data_encoded.drop("charges", axis=1).to_numpy()
y_data = data_encoded["charges"].to_numpy()

# training-validation-test-split
# keep 70 % of data for training
X_train, X_test, y_train, y_test = train_test_split(X_data, y_data, test_size=0.3)
# split the remaining 30% equally into validation and test set
X_val, X_test, y_val, y_test = train_test_split(X_test, y_test, test_size=0.5)

# function that fits the model to the training set
def fit_regression_model(X, y, hyperparameters):
    model = MLPRegressor(learning_rate_init=float(hyperparameters["learning_rate"]), hidden_layer_sizes=int(hyperparameters['num_layers']) * [int(hyperparameters['nodes_per_layer'])])
    model.fit(X, y)
    return model

# function that estimates the MSE over the data
def compute_mean_squared_error(X, y, model):
    predictions = model.predict(X)
    mse = np.mean((predictions - y) ** 2)
    return np.array(mse).reshape(-1, 1) # must be a numpy array


hyperparameter_search_space = DesignSpace().parse([
    {'name' : 'learning_rate', 'type' : 'num', 'lb' : 0.0001, 'ub' : 0.01},
    {'name' : 'num_layers', 'type' : 'int', 'lb' : 1, 'ub' : 3},
    {'name' : 'nodes_per_layer', 'type' : 'int', 'lb' : 20, 'ub' : 80}
])
hyperparameter_optimizer = HEBO(hyperparameter_search_space)

for i in range(10):
    hyperparameters = hyperparameter_optimizer.suggest(n_suggestions=1)
    model = fit_regression_model(X_train, y_train, hyperparameters)
    validation_error = compute_mean_squared_error(X_val, y_val, model)
    hyperparameter_optimizer.observe(hyperparameters, validation_error)

# get the hyperparameters with the minimum validation loss
best_hyperparameters = hyperparameter_optimizer.best_x
print(f'Used hyperparameters: {best_hyperparameters}')

# fit the model with the best hyperparameters
model = fit_regression_model(X_data, y_data, best_hyperparameters)

# compute and print the MSE in the test set
test_error = compute_mean_squared_error(X_test, y_test, model)[0, 0]
print('Mean Squared Error: ', test_error)
```
